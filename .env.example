# ── REQUIRED ────────────────────────────────────────────────────────────────────
# Fernet encryption key for sensitive DB fields.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your_fernet_key_here

# Admin password to access the dashboard UI
ADMIN_TOKEN=change_me_to_a_strong_password

# Public URL of this server (set once after first deploy)
WEBHOOK_BASE_URL=https://your-app.fly.dev

# ── OPTIONAL ────────────────────────────────────────────────────────────────────
# Database file path (default stores in /data for Docker volume)
DATABASE_URL=sqlite:///./data/dashboard.db

# Default Anthropic API key (can be set in UI Settings instead)
ANTHROPIC_API_KEY=sk-ant-...
